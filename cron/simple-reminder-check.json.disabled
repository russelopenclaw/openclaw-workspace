{
  "name": "Timely Reminders (30-min window)",
  "schedule": {
    "kind": "cron",
    "expr": "*/5 * * * *",
    "tz": "America/Chicago"
  },
  "payload": {
    "kind": "systemEvent",
    "text": "Check reminders due within 30 minutes. If any found, send Telegram alert via message tool."
  },
  "sessionTarget": "main",
  "enabled": true,
  "delivery": {
    "mode": "none"
  },
  "note": "Only alerts when reminders are within 30 min. Silent otherwise. Runs every 5 min."
}
